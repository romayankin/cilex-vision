global:
  scrape_interval: {{ monitoring_scrape_interval }}
  evaluation_interval: {{ monitoring_evaluation_interval }}

{% set excluded_hosts = monitoring_excluded_hosts | default([]) %}

rule_files:
  - /etc/prometheus/rules/*.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - {{ hostvars[groups['monitoring'][0]].ansible_host | default(groups['monitoring'][0]) }}:{{ prometheus_port }}

  - job_name: node-exporter
    static_configs:
      - targets:
{% set node_targets = namespace(items=[]) %}
{% for group_name in ['kafka', 'nats', 'timescaledb', 'minio', 'triton', 'monitoring', 'mlflow', 'cvat', 'services', 'edge_gateways'] %}
{%   for host in groups.get(group_name, []) %}
{%     if host not in excluded_hosts %}
{%       set target = (hostvars[host].ansible_host | default(host)) ~ ':' ~ node_exporter_port %}
{%       if target not in node_targets.items %}
{%         set _ = node_targets.items.append(target) %}
{%       endif %}
{%     endif %}
{%   endfor %}
{% endfor %}
{% for target in node_targets.items %}
          - {{ target }}
{% endfor %}

{% if groups.get('minio', []) %}
  - job_name: minio-cluster
    metrics_path: /minio/v2/metrics/cluster
    static_configs:
      - targets:
{%   for host in groups.get('minio', []) %}
{%     if host not in excluded_hosts %}
          - {{ hostvars[host].ansible_host | default(host) }}:{{ minio_api_port }}
{%     endif %}
{%   endfor %}

  - job_name: minio-bucket
    metrics_path: /minio/v2/metrics/bucket
    static_configs:
      - targets:
{%   for host in groups.get('minio', []) %}
          - {{ hostvars[host].ansible_host | default(host) }}:{{ minio_api_port }}
{%   endfor %}

  - job_name: minio-resource
    metrics_path: /minio/v2/metrics/resource
    static_configs:
      - targets:
{%   for host in groups.get('minio', []) %}
          - {{ hostvars[host].ansible_host | default(host) }}:{{ minio_api_port }}
{%   endfor %}

  - job_name: minio-node
    metrics_path: /minio/v2/metrics/node
    static_configs:
      - targets:
{%   for host in groups.get('minio', []) %}
          - {{ hostvars[host].ansible_host | default(host) }}:{{ minio_api_port }}
{%   endfor %}

{% endif %}
{% if groups.get('triton', []) %}
  - job_name: triton
    metrics_path: /metrics
    static_configs:
      - targets:
{%   for host in groups.get('triton', []) %}
{%     if host not in excluded_hosts %}
          - {{ hostvars[host].ansible_host | default(host) }}:{{ triton_metrics_port }}
{%     endif %}
{%   endfor %}

{% endif %}
{% if groups.get('edge_gateways', []) %}
  - job_name: edge-agent
    metrics_path: /metrics
    static_configs:
      - targets:
{%   for host in groups.get('edge_gateways', []) %}
{%     if host not in excluded_hosts %}
          - {{ hostvars[host].ansible_host | default(host) }}:{{ hostvars[host].edge_gateway_metrics_port | default(edge_gateway_metrics_port) }}
{%     endif %}
{%   endfor %}

{% endif %}
{% if mtmc_scrape_targets | default([]) | length > 0 %}
  - job_name: mtmc-service
    metrics_path: /metrics
    static_configs:
      - targets:
{%   for target in mtmc_scrape_targets | default([]) %}
          - {{ target }}
{%   endfor %}

{% endif %}
  - job_name: loki
    static_configs:
      - targets:
          - {{ hostvars[groups['monitoring'][0]].ansible_host | default(groups['monitoring'][0]) }}:{{ loki_port }}
