server:
  http_listen_port: {{ promtail_http_port }}
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yml

clients:
  - url: http://{{ hostvars[groups['monitoring'][0]].ansible_host | default(groups['monitoring'][0]) }}:{{ loki_port }}/loki/api/v1/push

scrape_configs:
  - job_name: docker
    pipeline_stages:
      - docker: {}
    static_configs:
      - targets:
          - localhost
        labels:
          job: docker
          host: {{ inventory_hostname }}
          __path__: /var/lib/docker/containers/*/*-json.log

