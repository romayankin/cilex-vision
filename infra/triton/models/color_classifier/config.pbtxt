# ResNet-18 — 10-class color classifier
# Classes: red, blue, white, black, silver, green, yellow, brown, orange, unknown
# Serves all 3 color attributes: vehicle_color, person_upper_color, person_lower_color
# Compute precision: FP16 (TensorRT), I/O precision: FP32
# See docs/triton-placement.md for full placement spec

name: "color_classifier"
platform: "tensorrt_plan"
max_batch_size: 32

input [
  {
    name: "images"
    data_type: TYPE_FP32
    dims: [3, 224, 224]
  }
]

output [
  {
    name: "probabilities"
    data_type: TYPE_FP32
    dims: [10]
  }
]

dynamic_batching {
  preferred_batch_size: [8, 16, 32]
  max_queue_delay_microseconds: 100000
}

instance_group [
  {
    count: 1
    kind: KIND_GPU
    gpus: [0]
  }
]

version_policy {
  latest {
    num_versions: 2
  }
}
