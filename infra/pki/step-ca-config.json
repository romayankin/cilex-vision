{
  "root": "/etc/step-ca/certs/root_ca.crt",
  "crt": "/etc/step-ca/certs/intermediate_ca.crt",
  "key": "/etc/step-ca/secrets/intermediate_ca_key",
  "address": ":9000",
  "dnsNames": [
    "ca.cilex.internal"
  ],
  "logger": {
    "format": "json"
  },
  "db": {
    "type": "badgerv2",
    "dataSource": "/var/lib/step-ca/db"
  },
  "crl": {
    "enabled": true
  },
  "authority": {
    "claims": {
      "minTLSCertDuration": "5m",
      "maxTLSCertDuration": "2160h",
      "defaultTLSCertDuration": "2160h",
      "disableRenewal": false,
      "allowRenewalAfterExpiry": false
    },
    "policy": {
      "x509": {
        "allow": {
          "dns": [
            "*.edge.cilex.internal",
            "*.core.cilex.internal",
            "ca.cilex.internal"
          ],
          "ip": [
            "10.42.0.0/16",
            "10.43.0.0/16"
          ],
          "uri": [
            "spiffe://cilex.internal/site/*",
            "spiffe://cilex.internal/core/*"
          ]
        },
        "allowWildcardNames": true
      }
    },
    "provisioners": [
      {
        "type": "jwk",
        "name": "ops-bootstrap",
        "key": {
          "use": "sig",
          "kty": "EC",
          "kid": "REPLACE_WITH_PROVISIONER_KID",
          "crv": "P-256",
          "alg": "ES256",
          "x": "REPLACE_WITH_BASE64URL_X",
          "y": "REPLACE_WITH_BASE64URL_Y"
        },
        "encryptedKey": "REPLACE_WITH_ENCRYPTED_JWK",
        "claims": {
          "minTLSCertDuration": "5m",
          "maxTLSCertDuration": "2160h",
          "defaultTLSCertDuration": "2160h",
          "disableRenewal": false,
          "allowRenewalAfterExpiry": false
        }
      },
      {
        "type": "ACME",
        "name": "internal-acme",
        "forceCN": true,
        "claims": {
          "minTLSCertDuration": "5m",
          "maxTLSCertDuration": "2160h",
          "defaultTLSCertDuration": "2160h",
          "disableRenewal": false,
          "allowRenewalAfterExpiry": false
        }
      }
    ]
  },
  "tls": {
    "minVersion": 1.2,
    "maxVersion": 1.3,
    "renegotiation": false
  }
}
