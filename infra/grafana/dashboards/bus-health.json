{
  "uid": "bus-health",
  "title": "Bus Health",
  "tags": ["cilex-vision", "kafka", "nats"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "site_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(bridge_messages_received_total, site_id)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Kafka Consumer Lag (Bulk Collector)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bulk_consumer_lag",
          "legendFormat": "{{ group }}/{{ topic }}/{{ partition }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Messages Consumed / sec (Bulk Collector)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (topic) (rate(bulk_messages_consumed_total[5m]))",
          "legendFormat": "{{ topic }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "NATS Consumer Lag (Bridge)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bridge_nats_consumer_lag{site_id=~\"$site_id\"}",
          "legendFormat": "{{ site_id }}/{{ lane }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Bridge Throughput (msg/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (site_id) (rate(bridge_messages_received_total{site_id=~\"$site_id\"}[5m]))",
          "legendFormat": "{{ site_id }} received",
          "refId": "A"
        },
        {
          "expr": "sum by (site_id) (rate(bridge_messages_produced_total{site_id=~\"$site_id\"}[5m]))",
          "legendFormat": "{{ site_id }} produced",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Bridge Spool Fill %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bridge_spool_fill_pct",
          "legendFormat": "Spool",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Spool Depth (messages)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bridge_spool_depth_messages",
          "legendFormat": "Messages",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Bridge NATS→Kafka Latency p95 (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, site_id) (rate(bridge_nats_to_kafka_latency_ms_bucket{site_id=~\"$site_id\"}[5m])))",
          "legendFormat": "{{ site_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Schema Rejections & DLQ / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (site_id) (rate(bridge_schema_rejection_total{site_id=~\"$site_id\"}[5m])) * 60",
          "legendFormat": "{{ site_id }} rejections",
          "refId": "A"
        },
        {
          "expr": "sum by (site_id) (rate(bridge_dlq_published_total{site_id=~\"$site_id\"}[5m])) * 60",
          "legendFormat": "{{ site_id }} DLQ",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Kafka Producer In-Flight & Produce Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bridge_kafka_producer_inflight",
          "legendFormat": "In-flight",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bridge_kafka_produce_latency_ms_bucket[5m])))",
          "legendFormat": "Produce p95 (ms)",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ]
}
