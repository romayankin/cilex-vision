{
  "uid": "inference-performance",
  "title": "Inference Performance",
  "tags": ["cilex-vision", "inference", "gpu"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "camera_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(inference_tracks_active, camera_id)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Frames Consumed / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(inference_frames_consumed_total[5m])",
          "legendFormat": "Consumed FPS",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Detections / sec by Class",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(inference_detections_total[5m])",
          "legendFormat": "{{ object_class }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Detection Inference Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(inference_latency_ms_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(inference_latency_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(inference_latency_ms_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Embedding Inference Latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(inference_embedding_latency_ms_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(inference_embedding_latency_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(inference_embedding_latency_ms_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "GPU VRAM Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(nv_gpu_memory_used_bytes / nv_gpu_memory_total_bytes) * 100",
          "legendFormat": "{{ gpu_uuid }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Triton Queue Delay (ms)",
      "description": "Average queue wait time per model. Threshold: 100ms warn, 500ms critical (triton-alerts.yml).",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "(rate(nv_inference_queue_duration_us_sum[5m]) / rate(nv_inference_queue_duration_us_count[5m])) / 1000",
          "legendFormat": "{{ model }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Active Tracks per Camera",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "inference_tracks_active{camera_id=~\"$camera_id\"}",
          "legendFormat": "{{ camera_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tracks Closed / min",
      "description": "Rate of tracks reaching TERMINATED state. Spikes may indicate ID switches or tracking instability.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(inference_tracks_closed_total{camera_id=~\"$camera_id\"}[5m]) * 60",
          "legendFormat": "{{ camera_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Consumer Lag (Inference Worker)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "inference_consumer_lag",
          "legendFormat": "{{ topic }}/{{ partition }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ]
}
