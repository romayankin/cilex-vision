{
  "uid": "stream-health",
  "title": "Stream Health",
  "tags": ["cilex-vision", "edge"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "camera_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(edge_camera_uptime_ratio, camera_id)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Camera Uptime %",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "edge_camera_uptime_ratio{camera_id=~\"$camera_id\"} * 100",
          "legendFormat": "{{ camera_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Cameras",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(edge_camera_uptime_ratio > 0)",
          "legendFormat": "Online",
          "refId": "A"
        },
        {
          "expr": "count(edge_camera_uptime_ratio == 0)",
          "legendFormat": "Offline",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Edge Buffer Fill",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "edge_buffer_fill_bytes",
          "legendFormat": "Buffer",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "max": 1073741824,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Decode Errors / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(edge_decode_errors_total{camera_id=~\"$camera_id\"}[5m]) * 60",
          "legendFormat": "{{ camera_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "NATS Publish Latency p95 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, camera_id) (rate(edge_nats_publish_latency_ms_bucket{camera_id=~\"$camera_id\"}[5m])))",
          "legendFormat": "{{ camera_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Motion Duty Cycle",
      "description": "Fraction of frames passing the motion filter: motion / (motion + static)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(edge_motion_frames_total{camera_id=~\"$camera_id\"}[5m]) / (rate(edge_motion_frames_total{camera_id=~\"$camera_id\"}[5m]) + rate(edge_static_frames_filtered_total{camera_id=~\"$camera_id\"}[5m]))",
          "legendFormat": "{{ camera_id }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Motion vs Static Frames / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(edge_motion_frames_total{camera_id=~\"$camera_id\"}[5m])",
          "legendFormat": "{{ camera_id }} motion",
          "refId": "A"
        },
        {
          "expr": "rate(edge_static_frames_filtered_total{camera_id=~\"$camera_id\"}[5m])",
          "legendFormat": "{{ camera_id }} static",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } }
    }
  ]
}
