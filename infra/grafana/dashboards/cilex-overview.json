{
  "uid": "cilex-overview",
  "title": "Cilex Vision — Overview",
  "tags": ["cilex-vision", "overview"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cameras Online",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "count(edge_camera_uptime_ratio > 0)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Motion Frames / sec",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(edge_motion_frames_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bridge→Kafka msg/sec",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(bridge_messages_produced_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Inference fps",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(inference_frames_consumed_total[1m]))", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Pipeline throughput (msg/s)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "sum(rate(edge_motion_frames_total[1m]))", "legendFormat": "edge motion", "refId": "A" },
        { "expr": "sum(rate(bridge_messages_received_total[1m]))", "legendFormat": "bridge consume", "refId": "B" },
        { "expr": "sum(rate(bridge_messages_produced_total[1m]))", "legendFormat": "bridge produce", "refId": "C" },
        { "expr": "sum(rate(inference_frames_consumed_total[1m]))", "legendFormat": "inference", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Inference latency (ms)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(inference_latency_ms_bucket[1m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(inference_latency_ms_bucket[1m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(inference_latency_ms_bucket[1m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Bridge spool depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "bridge_spool_depth_messages", "legendFormat": "msgs", "refId": "A" },
        { "expr": "bridge_spool_fill_pct", "legendFormat": "% full", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "NATS consumer lag",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "bridge_nats_consumer_lag", "legendFormat": "{{lane}} — {{site_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Active tracks (per camera)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "inference_tracks_active", "legendFormat": "{{camera_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Camera uptime ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "expr": "edge_camera_uptime_ratio", "legendFormat": "{{camera_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
