{
  "uid": "storage",
  "title": "Storage",
  "tags": ["cilex-vision", "timescaledb", "minio"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      },
      {
        "name": "table",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(bulk_rows_written_total, table)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rows Written / sec by Table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(bulk_rows_written_total{table=~\"$table\"}[5m])",
          "legendFormat": "{{ table }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Write Latency p99 (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, table) (rate(bulk_write_latency_ms_bucket{table=~\"$table\"}[5m])))",
          "legendFormat": "{{ table }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Write Errors / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(bulk_write_errors_total{table=~\"$table\"}[5m]) * 60",
          "legendFormat": "{{ table }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Rows Currently Staged",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "bulk_rows_staged{table=~\"$table\"}",
          "legendFormat": "{{ table }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Batch Size (avg rows per flush)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(bulk_batch_size_histogram_sum{table=~\"$table\"}[5m]) / rate(bulk_batch_size_histogram_count{table=~\"$table\"}[5m])",
          "legendFormat": "{{ table }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Duplicates Skipped / min",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(bulk_duplicates_skipped_total{table=~\"$table\"}[5m]) * 60",
          "legendFormat": "{{ table }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Messages Rejected / min",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (topic, reason) (rate(bulk_messages_rejected_total[5m])) * 60",
          "legendFormat": "{{ topic }}/{{ reason }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Decode Service Throughput",
      "description": "Frames consumed, decoded, sampled, and skipped by the decode service.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(decode_frames_consumed_total[5m])",
          "legendFormat": "Consumed",
          "refId": "A"
        },
        {
          "expr": "rate(decode_frames_decoded_total[5m])",
          "legendFormat": "Decoded",
          "refId": "B"
        },
        {
          "expr": "rate(decode_frames_sampled_total[5m])",
          "legendFormat": "Sampled (forwarded)",
          "refId": "C"
        },
        {
          "expr": "rate(decode_frames_skipped_total[5m])",
          "legendFormat": "Skipped (FPS gate)",
          "refId": "D"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Decode Consumer Lag",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "decode_consumer_lag",
          "legendFormat": "{{ topic }}/{{ partition }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    }
  ]
}
